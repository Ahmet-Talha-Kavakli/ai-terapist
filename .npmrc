enable-pre-post-scripts=true

# Allow build scripts for critical packages
# These are safe, well-known packages that require post-install scripts

# Package-specific build approvals
@nestjs/core[]=postinstall
@prisma/engines[]=postinstall
prisma[]=postinstall
@swc/core[]=postinstall
@parcel/watcher[]=postinstall
sharp[]=postinstall
